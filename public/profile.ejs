<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>My Profile - Elegant Fashion</title>
    <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Inter:wght@400;700&family=Poppins:wght@400;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/css/profile.css">
</head>

<body>
    <!-- Header (from partials) -->
    <%- include('partials/header.ejs', { currentPage: currentPage, user: user, cartCount: cartCount, wishlistCount:
        wishlistCount }) %>

        <!-- Hero Section -->
        <section class="hero-section">
            <div class="hero-overlay"></div>
            <div class="container">
                <div class="hero-content">
                    <h1 class="hero-title">My Profile</h1>
                    <p class="hero-desc">Manage your account information and preferences</p>
                </div>
            </div>
        </section>

        <!-- Main Content -->
        <main class="container" style="margin-bottom: 60px;">
            <% if (success) { %>
                <div class="alert alert-success">
                    ✓ <%= success %>
                </div>
                <% } %>

                    <% if (errors && errors.length> 0) { %>
                        <% errors.forEach(error=> { %>
                            <div class="alert alert-error">
                                ✕ <%= error %>
                            </div>
                            <% }) %>
                                <% } %>

                                    <div class="profile-container">
                                        <div class="profile-card">
                                            <!-- Profile Header -->
                                            <div class="profile-header">
                                                <div class="profile-avatar">
                                                    <% if (user.profilePhoto && user.profilePhoto
                                                        !=='https://via.placeholder.com/150?text=Profile' ) { %>
                                                        <img src="<%= user.profilePhoto %>" alt="Profile">
                                                        <% } else { %>
                                                            👤
                                                            <% } %>
                                                </div>
                                                <div class="profile-info">
                                                    <div class="profile-name">
                                                        <%= user.name %>
                                                    </div>
                                                    <div class="profile-email">
                                                        <%= user.email %>
                                                    </div>
                                                    <div class="profile-joined">Member since <%= new
                                                            Date(user.createdAt).toLocaleDateString('en-US', {
                                                            year: 'numeric' , month: 'long' , day: 'numeric' }) %>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Profile Body -->
                                            <div class="profile-body">
                                                <% if (!isEditing) { %>
                                                    <!-- View Mode -->
                                                    <div class="view-mode">
                                                        <% if (user.fullName) { %>
                                                            <div class="info-item">
                                                                <div class="info-label">Full Name</div>
                                                                <div class="info-value">
                                                                    <%= user.fullName %>
                                                                </div>
                                                            </div>
                                                            <% } %>

                                                                <% if (user.phone) { %>
                                                                    <div class="info-item">
                                                                        <div class="info-label">Phone</div>
                                                                        <div class="info-value">
                                                                            <%= user.phone %>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>

                                                                        <% if (user.dateOfBirth) { %>
                                                                            <div class="info-item">
                                                                                <div class="info-label">Date of Birth
                                                                                </div>
                                                                                <div class="info-value">
                                                                                    <%= new
                                                                                        Date(user.dateOfBirth).toLocaleDateString()
                                                                                        %>
                                                                                </div>
                                                                            </div>
                                                                            <% } %>

                                                                                <% if (user.gender && user.gender
                                                                                    !=='Prefer not to say' ) { %>
                                                                                    <div class="info-item">
                                                                                        <div class="info-label">Gender
                                                                                        </div>
                                                                                        <div class="info-value">
                                                                                            <%= user.gender %>
                                                                                        </div>
                                                                                    </div>
                                                                                    <% } %>

                                                                                        <% if (user.address) { %>
                                                                                            <div class="info-item full">
                                                                                                <div class="info-label">
                                                                                                    Address</div>
                                                                                                <div class="info-value">
                                                                                                    <%= user.address %>
                                                                                                </div>
                                                                                            </div>
                                                                                            <% } %>

                                                                                                <% if (user.city) { %>
                                                                                                    <div
                                                                                                        class="info-item">
                                                                                                        <div
                                                                                                            class="info-label">
                                                                                                            City</div>
                                                                                                        <div
                                                                                                            class="info-value">
                                                                                                            <%= user.city
                                                                                                                %>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <% } %>

                                                                                                        <% if
                                                                                                            (user.state)
                                                                                                            { %>
                                                                                                            <div
                                                                                                                class="info-item">
                                                                                                                <div
                                                                                                                    class="info-label">
                                                                                                                    State
                                                                                                                </div>
                                                                                                                <div
                                                                                                                    class="info-value">
                                                                                                                    <%= user.state
                                                                                                                        %>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                            <% } %>

                                                                                                                <% if
                                                                                                                    (user.zipCode)
                                                                                                                    { %>
                                                                                                                    <div
                                                                                                                        class="info-item">
                                                                                                                        <div
                                                                                                                            class="info-label">
                                                                                                                            Zip
                                                                                                                            Code
                                                                                                                        </div>
                                                                                                                        <div
                                                                                                                            class="info-value">
                                                                                                                            <%= user.zipCode
                                                                                                                                %>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                    <% }
                                                                                                                        %>

                                                                                                                        <% if
                                                                                                                            (user.country)
                                                                                                                            {
                                                                                                                            %>
                                                                                                                            <div
                                                                                                                                class="info-item">
                                                                                                                                <div
                                                                                                                                    class="info-label">
                                                                                                                                    Country
                                                                                                                                </div>
                                                                                                                                <div
                                                                                                                                    class="info-value">
                                                                                                                                    <%= user.country
                                                                                                                                        %>
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                            <% }
                                                                                                                                %>

                                                                                                                                <% if
                                                                                                                                    (user.bio)
                                                                                                                                    {
                                                                                                                                    %>
                                                                                                                                    <div
                                                                                                                                        class="info-item full">
                                                                                                                                        <div
                                                                                                                                            class="info-label">
                                                                                                                                            Bio
                                                                                                                                        </div>
                                                                                                                                        <div
                                                                                                                                            class="info-value">
                                                                                                                                            <%= user.bio
                                                                                                                                                %>
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                    <% }
                                                                                                                                        %>
                                                    </div>

                                                    <div class="button-group">
                                                        <button class="btn btn-primary"
                                                            onclick="location.href = location.href + '?edit=true';">Edit
                                                            Profile</button>
                                                    </div>
                                                    <% } else { %>
                                                        <!-- Edit Mode -->
                                                        <form id="editForm" method="POST" style="display: block;">
                                                            <!-- Personal Information -->
                                                            <div class="form-section">
                                                                <div class="form-section-title">Personal Information
                                                                </div>
                                                                <div class="form-row">
                                                                    <div class="form-group">
                                                                        <label class="form-label" for="fullName">Full
                                                                            Name</label>
                                                                        <input type="text" id="fullName" name="fullName"
                                                                            class="form-input <%= fieldErrors.fullName ? 'error' : '' %>"
                                                                            value="<%= user.fullName || '' %>"
                                                                            placeholder="Enter your full name">
                                                                        <% if (fieldErrors.fullName) { %>
                                                                            <div class="form-error">
                                                                                <%= fieldErrors.fullName %>
                                                                            </div>
                                                                            <% } %>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="form-label" for="phone">Phone
                                                                            Number</label>
                                                                        <input type="tel" id="phone" name="phone"
                                                                            class="form-input <%= fieldErrors.phone ? 'error' : '' %>"
                                                                            value="<%= user.phone || '' %>"
                                                                            placeholder="+1 (555) 123-4567">
                                                                        <% if (fieldErrors.phone) { %>
                                                                            <div class="form-error">
                                                                                <%= fieldErrors.phone %>
                                                                            </div>
                                                                            <% } %>
                                                                    </div>
                                                                </div>

                                                                <div class="form-row">
                                                                    <div class="form-group">
                                                                        <label class="form-label" for="dateOfBirth">Date
                                                                            of
                                                                            Birth</label>
                                                                        <input type="date" id="dateOfBirth"
                                                                            name="dateOfBirth" class="form-input"
                                                                            value="<%= user.dateOfBirth ? new Date(user.dateOfBirth).toISOString().split('T')[0] : '' %>">
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="form-label"
                                                                            for="gender">Gender</label>
                                                                        <select id="gender" name="gender"
                                                                            class="form-select">
                                                                            <option value="Prefer not to say"
                                                                                <%=user.gender==='Prefer not to say'
                                                                                ? 'selected' : '' %>>Prefer not to say
                                                                            </option>
                                                                            <option value="Male" <%=user.gender==='Male'
                                                                                ? 'selected' : '' %>>Male</option>
                                                                            <option value="Female"
                                                                                <%=user.gender==='Female' ? 'selected'
                                                                                : '' %>>Female</option>
                                                                            <option value="Other"
                                                                                <%=user.gender==='Other' ? 'selected'
                                                                                : '' %>>Other</option>
                                                                        </select>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <!-- Address Information -->
                                                            <div class="form-section">
                                                                <div class="form-section-title">Address Information
                                                                </div>
                                                                <div class="form-row full">
                                                                    <div class="form-group">
                                                                        <label class="form-label" for="address">Street
                                                                            Address</label>
                                                                        <input type="text" id="address" name="address"
                                                                            class="form-input"
                                                                            value="<%= user.address || '' %>"
                                                                            placeholder="123 Main Street">
                                                                    </div>
                                                                </div>

                                                                <div class="form-row">
                                                                    <div class="form-group">
                                                                        <label class="form-label"
                                                                            for="city">City</label>
                                                                        <input type="text" id="city" name="city"
                                                                            class="form-input"
                                                                            value="<%= user.city || '' %>"
                                                                            placeholder="New York">
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="form-label"
                                                                            for="state">State/Province</label>
                                                                        <input type="text" id="state" name="state"
                                                                            class="form-input"
                                                                            value="<%= user.state || '' %>"
                                                                            placeholder="NY">
                                                                    </div>
                                                                </div>

                                                                <div class="form-row">
                                                                    <div class="form-group">
                                                                        <label class="form-label"
                                                                            for="zipCode">Zip/Postal
                                                                            Code</label>
                                                                        <input type="text" id="zipCode" name="zipCode"
                                                                            class="form-input"
                                                                            value="<%= user.zipCode || '' %>"
                                                                            placeholder="10001">
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="form-label"
                                                                            for="country">Country</label>
                                                                        <input type="text" id="country" name="country"
                                                                            class="form-input"
                                                                            value="<%= user.country || '' %>"
                                                                            placeholder="United States">
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <!-- Additional Information -->
                                                            <div class="form-section">
                                                                <div class="form-section-title">Additional Information
                                                                </div>
                                                                <div class="form-row full">
                                                                    <div class="form-group">
                                                                        <label class="form-label" for="bio">Bio (About
                                                                            You)</label>
                                                                        <textarea id="bio" name="bio"
                                                                            class="form-textarea <%= fieldErrors.bio ? 'error' : '' %>"
                                                                            placeholder="Tell us a bit about yourself..."><%= user.bio || '' %></textarea>
                                                                        <% if (fieldErrors.bio) { %>
                                                                            <div class="form-error">
                                                                                <%= fieldErrors.bio %>
                                                                            </div>
                                                                            <% } %>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="button-group">
                                                                <button type="button" class="btn btn-secondary"
                                                                    onclick="location.href = location.href.split('?')[0];">Cancel</button>
                                                                <button type="submit" class="btn btn-primary">Save
                                                                    Changes</button>
                                                            </div>
                                                        </form>
                                                        <% } %>
                                            </div>
                                        </div>
                                    </div>
        </main>

        <!-- Footer (from partials) -->
        <%- include('partials/footer.ejs') %>
</body>

</html>