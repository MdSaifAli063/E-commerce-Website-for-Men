<body>
    <%- include('partials/header.ejs') %>

    <main>
        <section class="hero-section"
            style="background: linear-gradient(135deg, #1a2332 0%, #2d3748 50%, #d4af37 100%); padding: 80px 0; border-radius: 0 0 48px 48px; position: relative; overflow: hidden; margin-top: 0; margin-bottom: 10px;">
            <div style="position: absolute; inset: 0; background: rgba(0, 0, 0, 0.2); top: 0;">
            </div>
            <div class="container"
                style="position: relative; z-index: 1; text-align: center; width: 100%; max-width: 1200px; margin: 0 auto;">
                <div style="margin-bottom: 40px;">
                    <h1
                        style="font-size: 70px; font-family: 'Poppins', Arial, sans-serif; font-weight: 900; color: #d4af37; margin: 0 0 24px 0; line-height: 1.1; letter-spacing: 3px; text-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);">
                        Our Services
                    </h1>
                    <p
                        style="font-size: 18px; color: #cbd5e1; margin: 0 0 40px 0; max-width: 800px; margin-left: auto; margin-right: auto; line-height: 1.8;">
                        Professional tailoring, custom alterations, and personalized styling to transform your wardrobe
                        with precision and excellence. From expert fittings and embroidery to wardrobe makeovers and
                        style consultations, our full suite of services has you covered.
                    </p>
                </div>
                <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px;">
                    <!-- changed to link to booking page -->
                    <a href="/booking" class="btn-gold"
                        style="padding: 14px 50px; font-size: 20px; text-decoration:none; display:inline-block;">Book
                        Now</a>
                </div>
                <div style="display: flex; justify-content: center; gap: 50px; flex-wrap: wrap;">
                    <div style="color: #fff; text-align: center;">
                        <div style="font-size: 36px; font-weight: 900; color: #d4af37; margin-bottom: 8px;">10+</div>
                        <div style="font-size: 14px; color: #cbd5e1;">Service Types</div>
                    </div>
                    <div style="color: #fff; text-align: center;">
                        <div style="font-size: 36px; font-weight: 900; color: #d4af37; margin-bottom: 8px;">5000+</div>
                        <div style="font-size: 14px; color: #cbd5e1;">Happy Clients</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="section bg-cream">
            <div class="container">
                <div class="section-title">Services Offered</div>
                <div class="section-desc">Explore a wide range of services to elevate your style – from custom tailoring
                    to
                    wardrobe refreshes, consultations, and more.</div>
                <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
                    <a href="/booking?service=Custom%20Tailoring" style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">🧵</div>
                                <div class="card-title">Custom Tailoring</div>
                                <div class="card-desc">Personalized fits for suits and shirts.</div>
                            </div>
                        </div>
                    </a>
                    <a href="/booking?service=Alterations" style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">✂️</div>
                                <div class="card-title">Alterations</div>
                                <div class="card-desc">Expert adjustments for perfect fit.</div>
                            </div>
                        </div>
                    </a>
                    <a href="/booking?service=Style%20Consultation" style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">💼</div>
                                <div class="card-title">Style Consultation</div>
                                <div class="card-desc">One-on-one advice to refine your look.</div>
                            </div>
                        </div>
                    </a>
                    <a href="/booking?service=Wardrobe%20Refresh" style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">👕</div>
                                <div class="card-title">Wardrobe Refresh</div>
                                <div class="card-desc">Update and modernize your existing pieces.</div>
                            </div>
                        </div>
                    </a>
                    <a href="/booking?service=Stitching%20%26%20Repairs" style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">🪡</div>
                                <div class="card-title">Stitching & Repairs</div>
                                <div class="card-desc">High-quality stitching and mending services.</div>
                            </div>
                        </div>
                    </a>
                    <a href="/booking?service=Embroidery%20%26%20Monogramming"
                        style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">🧷</div>
                                <div class="card-title">Embroidery & Monogramming</div>
                                <div class="card-desc">Personalize garments with custom designs.</div>
                            </div>
                        </div>
                    </a>
                    <a href="/booking?service=Personal%20Shopping" style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">🛍️</div>
                                <div class="card-title">Personal Shopping</div>
                                <div class="card-desc">Assistance selecting the perfect outfits.</div>
                            </div>
                        </div>
                    </a>
                    <a href="/booking?service=Suit%20Fitting%20%26%20Design"
                        style="text-decoration:none;color:inherit;">
                        <div class="card">
                            <div class="card-body">
                                <div class="card-icon">👔</div>
                                <div class="card-title">Suit Fitting & Design</div>
