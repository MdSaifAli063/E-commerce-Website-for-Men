<!DOCTYPE html>
<html lang="en" style="height:100%">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cart - Elegant Fashion</title>
    <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Inter:wght@400;700&family=Poppins:wght@400;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/cart.css">
</head>

<body>
    <%- include('partials/header.ejs') %>

        <main>
            <section class="hero-section"
                style="background: linear-gradient(135deg, #1a2332 0%, #2d3748 50%, #d4af37 100%); padding: 80px 0; border-radius: 0 0 48px 48px; position: relative; overflow: hidden; margin-top: 0; margin-bottom: 60px;">
                <div style="position: absolute; inset: 0; background: rgba(0, 0, 0, 0.2); top: 0;">
                </div>
                <div class="container"
                    style="position: relative; z-index: 1; text-align: center; width: 100%; max-width: 1200px; margin: 0 auto;">
                    <div style="margin-bottom: 40px;">
                        <h1
                            style="font-size: 70px; font-family: 'Poppins', Arial, sans-serif; font-weight: 900; color: #d4af37; margin: 0 0 24px 0; line-height: 1.1; letter-spacing: 3px; text-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);">
                            Your Shopping Cart
                        </h1>
                        <p
                            style="font-size: 18px; color: #cbd5e1; margin: 0 0 40px 0; max-width: 800px; margin-left: auto; margin-right: auto; line-height: 1.8;">
                            Review your selected items and proceed to secure checkout with ease.
                        </p>
                    </div>
                    <div style="display: flex; justify-content: center; gap: 50px; flex-wrap: wrap;">
                        <div style="color: #fff; text-align: center;">
                            <div style="font-size: 36px; font-weight: 900; color: #d4af37; margin-bottom: 8px;">🛒</div>
                            <div style="font-size: 14px; color: #cbd5e1;">Easy Checkout</div>
                        </div>
                        <div style="color: #fff; text-align: center;">
                            <div style="font-size: 36px; font-weight: 900; color: #d4af37; margin-bottom: 8px;">💳</div>
                            <div style="font-size: 14px; color: #cbd5e1;">Secure Payment</div>
                        </div>
                        <div style="color: #fff; text-align: center;">
                            <div style="font-size: 36px; font-weight: 900; color: #d4af37; margin-bottom: 8px;">✓</div>
                            <div style="font-size: 14px; color: #cbd5e1;">Order Confirmation</div>
                        </div>
                    </div>
                </div>
            </section>

            <% const items=(typeof cart !=='undefined' ? cart : []) || []; %>
                <section class="section">
                    <div class="container">
                        <div class="section-title">Cart Items</div>
                        <div class="section-desc">Items in your cart</div>
                        <div style="max-width:800px; margin:0 auto;">
                            <% if (items.length===0) { %>
                                <p style="text-align:center; color:#4a5568; font-size:18px;">Your cart is empty.</p>
                                <% } else { %>
                                    <% const parsePrice=(value)=> {
                                        const raw = String(value || '').trim();

                                        // Handle numbers first
                                        if (typeof value === 'number') return value;

                                        // Try currency symbols first
                                        const currencyMatches = raw.match(/₹\s*[\d,]+\.?\d*/g);
                                        if (currencyMatches && currencyMatches.length > 0) {
                                        const lastPrice = currencyMatches[currencyMatches.length - 1];
                                        const cleaned = lastPrice.replace(/[^0-9.]/g, '').replace(/,/g, '');
                                        const num = Number(cleaned);
                                        if (!Number.isNaN(num) && num >= 0) return num;
                                        }

                                        // Fallback: numeric matches - handles both "6375" and "6,375"
                                        const matches = raw.match(/\d+(?:,\d{3})*(?:\.\d+)?/g);
                                        if (!matches || matches.length === 0) return 0;

                                        // If percentage found, pick largest number
                                        if (raw.includes('%') && matches.length > 1) {
                                        const nums = matches.map(v => Number(v.replace(/,/g, ''))).filter(v =>
                                        !Number.isNaN(v));
                                        const largest = nums.reduce((m, n) => n > m ? n : m, 0);
                                        if (largest > 0) return largest;
                                        }

                                        // Fallback to last match
                                        const lastNum = Number(matches[matches.length - 1].replace(/,/g, ''));
                                        return Number.isNaN(lastNum) ? 0 : lastNum;
                                        };
                                        const cartTotal = items.reduce((sum, item) => {
                                        const price = parsePrice(item.price);
                                        const quantity = Number(item.quantity || 1);
                                        return sum + price * quantity;
                                        }, 0);
                                        items.forEach(item=> { %>
                                        <div class="card cart-item" data-title="<%= item.title %>"
                                            data-price="<%= parsePrice(item.price) %>">
                                            <div class="card-image">
                                                <% if (item.image) { %>
                                                    <img src="<%= item.image %>" alt="<%= item.title %>" />
                                                    <% } else { %>
                                                        <div class="image-placeholder">IMG</div>
                                                        <% } %>
                                            </div>
                                            <div class="card-body">
                                                <div class="cart-item-info">
                                                    <div class="card-title">
                                                        <%= item.title %>
                                                    </div>
                                                    <div class="card-desc">
                                                        <%= item.desc || 'Nice product choice' %>
                                                    </div>
                                                    <div class="card-price">₹<%= parsePrice(item.price).toFixed(2) %>
                                                    </div>
                                                </div>
                                                <div class="cart-item-actions">
                                                    <div class="quantity-controls">
                                                        <button class="qty-btn decrease"
                                                            title="Decrease quantity">-</button>
                                                        <span class="qty-value">
                                                            <%= item.quantity || 1 %>
                                                        </span>
                                                        <button class="qty-btn increase"
                                                            title="Increase quantity">+</button>
                                                    </div>
                                                    <button class="btn-danger remove-from-cart"
                                                        title="Remove item">Remove</button>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <div class="cart-summary">
                                                <div class="summary-label">Cart Total</div>
                                                <div class="summary-value">₹<%= cartTotal.toFixed(2) %>
                                                </div>
                                            </div>
                                            <% } %>
                        </div>
                        <div style="text-align:center; margin-top:48px;">
                            <button class="btn-gold">Checkout</button>
                        </div>
                    </div>
                </section>
        </main>

        <%- include('partials/footer.ejs') %>
            <script>
                document.addEventListener("DOMContentLoaded", () => {
                    // Nav active state and keyboard support
                    const navButtons = document.querySelectorAll("nav button");
                    navButtons.forEach((btn) => {
                        btn.addEventListener("click", () => {
                            navButtons.forEach((b) => b.classList.remove("active"));
                            btn.classList.add("active");
                        });
                        btn.addEventListener("keydown", (e) => {
                            if (e.key === "Enter" || e.key === " ") {
                                e.preventDefault();
                                btn.click();
                            }
                        });
                    });

                    // Newsletter form (demo)
                    const newsletterForm = document.querySelector(".newsletter-form");
                    newsletterForm?.addEventListener("submit", (e) => {
                        e.preventDefault();
                        alert("Thank you for subscribing!");
                    });

                    // Sticky header shadow
                    const header = document.querySelector("header");
                    const baseShadow = "0 10px 30px rgba(26, 35, 50, 0.15)";
                    const scrolledShadow = "0 10px 30px rgba(26, 35, 50, 0.25)";
                    function updateHeaderShadow() {
                        if (!header) return;
                        header.style.boxShadow = window.scrollY > 10 ? scrolledShadow : baseShadow;
                    }
                    updateHeaderShadow();
                    window.addEventListener("scroll", updateHeaderShadow, { passive: true });

                    // Search and Cart actions (demo)
                    document
                        .querySelector('.search-form')
                        ?.addEventListener("submit", (e) => {
                            e.preventDefault();
                            const query = e.target.querySelector('input').value.trim();
                            if (query) {
                                alert(`Searching for: "${query}" - functionality coming soon!`);
                            } else {
                                alert("Please enter a search term.");
                            }
                        });

                    document
                        .querySelector('.header-actions button[title="Cart"]')
                        ?.addEventListener("click", () => {
                            location.href = '/cart';
                        });

                    const refreshCartTotal = () => {
                        const cartItems = Array.from(document.querySelectorAll('.cart-item'));
                        const totalElem = document.querySelector('.summary-value');
                        if (!totalElem) return;
                        const total = cartItems.reduce((sum, card) => {
                            const price = Number(card.getAttribute('data-price')) || 0;
                            const qty = Number(card.querySelector('.qty-value')?.textContent.trim()) || 1;
                            return sum + price * qty;
                        }, 0);
                        totalElem.textContent = '₹' + total.toFixed(2);
                    };

                    const updateCartItem = (title, action) => {
                        const card = document.querySelector(`.cart-item[data-title="${CSS.escape(title)}"]`);
                        const price = card?.getAttribute('data-price') || '0';
                        const body = `title=${encodeURIComponent(title)}&price=${encodeURIComponent(price)}`;
                        const path = action === 'increase' ? '/cart/add' : '/cart/decrease';
                        fetch(path, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body,
                        })
                            .then((r) => r.json())
                            .then((data) => {
                                if (!data || !data.success) return;
                                const card = document.querySelector(`.cart-item[data-title="${CSS.escape(title)}"]`);
                                if (!card) return;
                                const qtyElem = card.querySelector('.qty-value');
                                let qty = Number(qtyElem.textContent.trim()) || 1;
                                qty = action === 'increase' ? qty + 1 : qty - 1;
                                if (qty < 1) {
                                    card.remove();
                                } else {
                                    qtyElem.textContent = String(qty);
                                }
                                if (document.querySelectorAll('.cart-item').length === 0) {
                                    const hold = document.querySelector('section .container > div[style*="max-width:800px"]');
                                    if (hold) {
                                        hold.innerHTML = '<p style="text-align:center; color:#4a5568; font-size:18px;">Your cart is empty.</p>';
                                    }
                                }

                                const totalElem = document.querySelector('.summary-value');
                                if (totalElem && typeof data.total === 'number') {
                                    totalElem.textContent = '₹' + data.total.toFixed(2);
                                } else {
                                    refreshCartTotal();
                                }
                            });
                    };

                    document.querySelectorAll('.qty-btn.increase').forEach((btn) => {
                        btn.addEventListener('click', (e) => {
                            e.stopPropagation();
                            const card = btn.closest('.cart-item');
                            const title = card?.getAttribute('data-title');
                            if (!title) return;
                            updateCartItem(title, 'increase');
                        });
                    });

                    document.querySelectorAll('.qty-btn.decrease').forEach((btn) => {
                        btn.addEventListener('click', (e) => {
                            e.stopPropagation();
                            const card = btn.closest('.cart-item');
                            const title = card?.getAttribute('data-title');
                            if (!title) return;
                            updateCartItem(title, 'decrease');
                        });
                    });

                    document.querySelectorAll('.remove-from-cart').forEach((btn) => {
                        btn.addEventListener('click', (e) => {
                            e.stopPropagation();
                            const card = btn.closest('.cart-item');
                            const title = card?.getAttribute('data-title');
                            if (!title) return;
                            fetch('/cart/remove', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: `title=${encodeURIComponent(title)}`,
                            }).then((r) => r.json()).then((data) => {
                                if (!data || !data.success) return;
                                card.remove();
                                if (document.querySelectorAll('.cart-item').length === 0) {
                                    const hold = document.querySelector('section .container > div[style*="max-width:800px"]');
                                    if (hold) {
                                        hold.innerHTML = '<p style="text-align:center; color:#4a5568; font-size:18px;">Your cart is empty.</p>';
                                    }
                                }

                                const totalElem = document.querySelector('.summary-value');
                                if (totalElem && typeof data.total === 'number') {
                                    totalElem.textContent = '₹' + data.total.toFixed(2);
                                } else {
                                    refreshCartTotal();
                                }
                            });
                        });
                    });

                    const checkoutBtn = document.querySelector('.btn-gold');
                    checkoutBtn?.addEventListener('click', () => {
                        const cartItems = document.querySelectorAll('.cart-item');
                        if (!cartItems.length) {
                            alert('Your cart is empty. Add items before checkout.');
                            return;
                        }

                        checkoutBtn.disabled = true;
                        checkoutBtn.textContent = 'Processing...';

                        fetch('/checkout', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: '',
                        })
                            .then((r) => r.json())
                            .then((data) => {
                                if (data && data.success) {
                                    alert(`Checkout success! Order ${data.order.id} created with total ₹${Number(data.order.total).toFixed(2)}`);
                                    window.location.href = '/orders';
                                } else {
                                    const msg = (data && data.message) || 'Unable to complete checkout.';
                                    alert(msg);
                                }
                            })
                            .catch((err) => {
                                console.error('Checkout failed:', err);
                                alert('Checkout failed. Please try again.');
                            })
                            .finally(() => {
                                checkoutBtn.disabled = false;
                                checkoutBtn.textContent = 'Checkout';
                            });
                    });

                    refreshCartTotal();

                    document
                        .querySelector('.header-actions button[title="Wishlist"]')
                        ?.addEventListener("click", () => {
                            location.href = '/wishlist';
                        });

                    // Account dropdown (Log in / Sign up / Profile / Orders / Logout)
                    const accountBtn = document.getElementById("accountBtn");
                    const accountMenu = document.getElementById("accountMenu");

                    function openMenu() {
                        if (!accountMenu || !accountBtn) return;
                        accountMenu.classList.add("open");
                        accountBtn.setAttribute("aria-expanded", "true");
                        const firstItem = accountMenu.querySelector(".dropdown-item");
                        firstItem?.focus();
                    }

                    function closeMenu() {
                        if (!accountMenu || !accountBtn) return;
                        accountMenu.classList.remove("open");
                        accountBtn.setAttribute("aria-expanded", "false");
                    }

                    function toggleMenu() {
                        if (!accountMenu || !accountBtn) return;
                        const isOpen = accountMenu.classList.contains("open");
                        isOpen ? closeMenu() : openMenu();
                    }

                    accountBtn?.addEventListener("click", (e) => {
                        e.stopPropagation();
                        toggleMenu();
                    });

                    // Close on outside click
                    document.addEventListener("click", (e) => {
                        if (!accountMenu || !accountBtn) return;
                        const target = e.target;
                        const clickInsideMenu = accountMenu.contains(target);
                        const clickOnBtn = accountBtn.contains(target);
                        if (!clickInsideMenu && !clickOnBtn) {
                            closeMenu();
                        }
                    });

                    // Close menu when clicking any menu item
                    accountMenu?.addEventListener("click", (e) => {
                        const a = e.target.closest("a.dropdown-item");
                        if (a) {
                            // Allow navigation; just close the menu visually
                            closeMenu();
                        }
                    });

                    // Keyboard handling: Escape to close, Tab to cycle within menu
                    document.addEventListener("keydown", (e) => {
                        if (!accountMenu || !accountBtn) return;

                        if (e.key === "Escape" && accountMenu.classList.contains("open")) {
                            e.preventDefault();
                            closeMenu();
                            accountBtn.focus();
                            return;
                        }

                        if (e.key === "Tab" && accountMenu.classList.contains("open")) {
                            const focusables = Array.from(
                                accountMenu.querySelectorAll('.dropdown-item, [role="menuitem"], a[href], button:not([disabled])')
                            );
                            if (focusables.length === 0) return;

                            const currentIndex = focusables.indexOf(document.activeElement);
                            let nextIndex = currentIndex;

                            if (e.shiftKey) {
                                nextIndex = currentIndex <= 0 ? focusables.length - 1 : currentIndex - 1;
                            } else {
                                nextIndex = currentIndex === focusables.length - 1 ? 0 : currentIndex + 1;
                            }

                            // If focus is not inside menu yet, start at first/last based on tab direction
                            if (currentIndex === -1) {
                                nextIndex = e.shiftKey ? focusables.length - 1 : 0;
                            }

                            e.preventDefault();
                            focusables[nextIndex].focus();
                        }
                    });
                });
            </script>
</body>

</html>